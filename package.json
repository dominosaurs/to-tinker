{
    "$schema": "https://json.schemastore.org/package.json",
    "activationEvents": [
        "onLanguage:php",
        "onCommand:toTinker.runPrimary",
        "onCommand:toTinker.runSelection",
        "onCommand:toTinker.runSelectionDisableSandbox",
        "onCommand:toTinker.runFile",
        "onCommand:toTinker.runFileDisableSandbox",
        "onCommand:toTinker.runMethod",
        "onCommand:toTinker.runMethodDisableSandbox",
        "onCommand:toTinker.runMethodAt",
        "onCommand:toTinker.showLogs"
    ],
    "author": {
        "name": "dominosaurs",
        "url": "https://github.com/dominosaurs"
    },
    "bugs": {
        "url": "https://github.com/dominosaurs/to-tinker/issues"
    },
    "categories": [
        "Other"
    ],
    "contributes": {
        "commands": [
            {
                "category": "To Tinker",
                "command": "toTinker.showLogs",
                "title": "Show Logs"
            },
            {
                "category": "To Tinker",
                "command": "toTinker.runPrimary",
                "enablement": "editorLangId == php",
                "icon": {
                    "dark": "assets/images/icon32.png",
                    "light": "assets/images/icon32.png"
                },
                "title": "To Tinker: Run"
            },
            {
                "category": "To Tinker",
                "command": "toTinker.runSelection",
                "enablement": "editorLangId == php",
                "title": "To Tinker"
            },
            {
                "category": "To Tinker",
                "command": "toTinker.runSelectionDisableSandbox",
                "enablement": "editorLangId == php",
                "title": "To Tinker (Disable Sandbox)"
            },
            {
                "category": "To Tinker",
                "command": "toTinker.runFile",
                "enablement": "editorLangId == php",
                "title": "Run File"
            },
            {
                "category": "To Tinker",
                "command": "toTinker.runFileDisableSandbox",
                "enablement": "editorLangId == php",
                "title": "Run File (Disable Sandbox)"
            },
            {
                "category": "To Tinker",
                "command": "toTinker.runMethod",
                "enablement": "editorLangId == php",
                "title": "Run Method"
            },
            {
                "category": "To Tinker",
                "command": "toTinker.runMethodDisableSandbox",
                "enablement": "editorLangId == php",
                "title": "Run Method (Disable Sandbox)"
            }
        ],
        "configuration": {
            "properties": {
                "toTinker.clearOutputOnRun": {
                    "default": true,
                    "description": "Clear the To Tinker output channel before each run.",
                    "type": "boolean"
                },
                "toTinker.codeLens.enabled": {
                    "default": true,
                    "description": "Show To Tinker CodeLens above supported PHP methods.",
                    "type": "boolean"
                },
                "toTinker.phpPath": {
                    "default": "",
                    "description": "Path to the PHP executable. Leave empty to use php from PATH.",
                    "type": "string"
                },
                "toTinker.sandbox.defaultEnabled": {
                    "default": true,
                    "description": "Enable the partial sandbox by default.",
                    "type": "boolean"
                },
                "toTinker.sandbox.fakeStorage": {
                    "default": false,
                    "description": "Also fake Laravel storage disks inside sandboxed runs.",
                    "type": "boolean"
                },
                "toTinker.timeoutSeconds": {
                    "default": 15,
                    "description": "Timeout for the spawned artisan tinker process.",
                    "minimum": 1,
                    "type": "number"
                }
            },
            "title": "To Tinker"
        },
        "keybindings": [
            {
                "command": "toTinker.runPrimary",
                "key": "ctrl+r",
                "mac": "cmd+r",
                "when": "editorTextFocus && editorLangId == php"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "toTinker.runSelection",
                    "when": "false"
                },
                {
                    "command": "toTinker.runSelectionDisableSandbox",
                    "when": "false"
                },
                {
                    "command": "toTinker.runFile",
                    "when": "false"
                },
                {
                    "command": "toTinker.runFileDisableSandbox",
                    "when": "false"
                },
                {
                    "command": "toTinker.runMethod",
                    "when": "false"
                },
                {
                    "command": "toTinker.runMethodDisableSandbox",
                    "when": "false"
                }
            ],
            "editor/context": [
                {
                    "command": "toTinker.runSelection",
                    "group": "navigation@10",
                    "when": "editorLangId == php && editorHasSelection"
                },
                {
                    "command": "toTinker.runSelectionDisableSandbox",
                    "group": "navigation@11",
                    "when": "editorLangId == php && editorHasSelection"
                }
            ],
            "editor/title": [
                {
                    "command": "toTinker.runPrimary",
                    "group": "navigation",
                    "when": "editorLangId == php && !editorReadonly && !inDiffEditor"
                }
            ]
        }
    },
    "description": "Run any PHP or Laravel code in one click from VS Code ⚡",
    "devDependencies": {
        "@biomejs/biome": "2.4.12",
        "@types/node": "^24.6.0",
        "@types/vscode": "^1.99.0",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.6.2",
        "preact": "^10.29.1",
        "preact-render-to-string": "^6.6.7",
        "shiki": "^4.0.2",
        "typescript": "^5.9.3",
        "vite": "^7.1.10",
        "vite-plugin-static-copy": "^3.1.4",
        "vitest": "^3.2.4"
    },
    "displayName": "To Tinker",
    "engines": {
        "vscode": "^1.99.0"
    },
    "files": [
        "assets/images/icon256.png",
        "assets/images/icon32.png",
        "out/**",
        "LICENSE",
        "package.json",
        "README.md"
    ],
    "homepage": "https://github.com/dominosaurs/to-tinker#readme",
    "icon": "assets/images/icon256.png",
    "keywords": [
        "laravel",
        "laravel tinker",
        "artisan",
        "artisan tinker",
        "php",
        "php selection",
        "vscode",
        "vscode laravel",
        "run selection",
        "run file",
        "run method",
        "debugging"
    ],
    "license": "MIT",
    "main": "./out/extension.js",
    "name": "to-tinker",
    "preview": true,
    "publisher": "dominosaurs",
    "repository": {
        "type": "git",
        "url": "https://github.com/dominosaurs/to-tinker.git"
    },
    "scripts": {
        "build": "vite build",
        "lint": "biome check --write && tsc --noEmit",
        "package": "vsce package --no-dependencies --allow-missing-repository",
        "prepackage": "bun run build",
        "test": "vitest run"
    },
    "version": "0.1.0"
}
